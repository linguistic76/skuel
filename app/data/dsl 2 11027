                   entity.uid,
                   link.target_uid,
                   self._map_link_type_to_semantic(link.type),
                   source=f"dsl_link_{link.type}"
               )

           # Store metadata
           entity.metadata["dsl_parsed"] = {
               "energy_states": parsed.energy_states,
               "duration_minutes": parsed.duration_minutes,
               "repeat_pattern": parsed.repeat_pattern,
               "source": "dsl_v0.3"
           }

           return Result.ok({"entity": entity, "relationships_created": count})
