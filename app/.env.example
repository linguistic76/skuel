# =============================================================================
# SKUEL Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Do NOT commit .env to version control.

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
SKUEL_ENVIRONMENT=local          # local | development | staging | production | test

# -----------------------------------------------------------------------------
# Neo4j Database
# -----------------------------------------------------------------------------
NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=neo4j
# NEO4J_MAX_CONNECTION_POOL_SIZE=50
# NEO4J_CONNECTION_TIMEOUT=30
# NEO4J_ENCRYPTED=false          # true for AuraDB (neo4j+s://)

# -----------------------------------------------------------------------------
# AI / LLM (required for INTELLIGENCE_TIER=full)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-key
INTELLIGENCE_TIER=full           # core ($0, analytics only) | full (analytics + AI)

# -----------------------------------------------------------------------------
# Embeddings (HuggingFace Inference API — bge-large-en-v1.5)
# -----------------------------------------------------------------------------
HF_API_TOKEN=hf_your-huggingface-token
# EMBEDDING_ENABLED=false
# EMBEDDING_VECTOR_SEARCH_ENABLED=false
# EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
# EMBEDDING_DIMENSION=1024
# EMBEDDING_VERSION=v2
# EMBEDDING_BATCH_SIZE=25

# -----------------------------------------------------------------------------
# Audio (Deepgram — voice journal transcription)
# -----------------------------------------------------------------------------
DEEPGRAM_API_KEY=your-deepgram-key

# -----------------------------------------------------------------------------
# Session Security
# -----------------------------------------------------------------------------
SESSION_SECRET_KEY=generate-a-random-secret-here   # Required in production; auto-generated in local/dev
# SKUEL_DEFAULT_DEV_USER=user_mike                 # Auto-login user for local development

# -----------------------------------------------------------------------------
# API Server
# -----------------------------------------------------------------------------
# API_HOST=0.0.0.0
# API_PORT=8000
# API_DEBUG=false
# API_RELOAD=false

# -----------------------------------------------------------------------------
# Vault (Obsidian content source)
# -----------------------------------------------------------------------------
# VAULT_ROOT=/home/mike/0bsidian/skuel
# VAULT_ENABLED=true
# AUTO_SYNC_VAULT=true
# WATCH_VAULT=false
# SYNC_INTERVAL_MINUTES=30

# -----------------------------------------------------------------------------
# Cache (optional — in-memory by default)
# -----------------------------------------------------------------------------
# CACHE_ENABLED=true

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# LOG_LEVEL=DEBUG                 # DEBUG | INFO | WARNING | ERROR
