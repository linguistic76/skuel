  3. Missing Relationship Property Schemas

  Current State: Properties defined but not enforced
  "APPLIES_KNOWLEDGE": RelationshipSpec(
      properties={"application_confidence": float},  # Just documentation
  )

  Opportunity: Add runtime property validation
  @dataclass(frozen=True)
  class RelationshipSpec:
      # ... existing fields
      required_properties: list[str] = field(default_factory=list)

      def validate_properties(self, properties: dict[str, Any]) -> list[str]:
          """Return list of validation errors."""
          errors = []
          for prop_name, prop_type in (self.properties or {}).items():
              if prop_name in self.required_properties and prop_name not in properties:
                  errors.append(f"Missing required property: {prop_name}")
              elif prop_name in properties and not isinstance(properties[prop_name], prop_type):
                  errors.append(f"Invalid type for {prop_name}")
          return errors

