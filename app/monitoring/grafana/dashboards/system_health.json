{
  "title": "SKUEL System Health",
  "tags": ["skuel", "system", "health", "phase2"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "type": "row",
      "title": "HTTP Request Metrics",
      "collapsed": false
    },
    {
      "id": 2,
      "gridPos": { "x": 0, "y": 1, "w": 8, "h": 8 },
      "type": "timeseries",
      "title": "HTTP Request Rate (QPS)",
      "targets": [
        {
          "expr": "rate(skuel_http_requests_total[5m])",
          "legendFormat": "{{method}} {{endpoint}} ({{status}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "unit": "reqps"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "mean", "max"]
        }
      }
    },
    {
      "id": 3,
      "gridPos": { "x": 8, "y": 1, "w": 8, "h": 8 },
      "type": "timeseries",
      "title": "HTTP Request Latency (p50, p95, p99)",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(skuel_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(skuel_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(skuel_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "unit": "s"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "mean", "max"]
        }
      }
    },
    {
      "id": 4,
      "gridPos": { "x": 16, "y": 1, "w": 8, "h": 8 },
      "type": "timeseries",
      "title": "HTTP Error Rate (%)",
      "targets": [
        {
          "expr": "100 * (sum(rate(skuel_http_requests_total{status=~\"5..\"}[5m])) or vector(0)) / (sum(rate(skuel_http_requests_total[5m])) or vector(1))",
          "legendFormat": "5xx errors",
          "refId": "A"
        },
        {
          "expr": "100 * (sum(rate(skuel_http_requests_total{status=~\"4..\"}[5m])) or vector(0)) / (sum(rate(skuel_http_requests_total[5m])) or vector(1))",
          "legendFormat": "4xx errors",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "mean", "max"]
        }
      }
    },
    {
      "id": 5,
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 1 },
      "type": "row",
      "title": "Database (Neo4j) Metrics",
      "collapsed": false
    },
    {
      "id": 6,
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 8 },
      "type": "timeseries",
      "title": "Neo4j Query Rate by Operation",
      "targets": [
        {
          "expr": "rate(skuel_neo4j_queries_total[5m])",
          "legendFormat": "{{operation}} {{label}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "unit": "qps"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "mean", "max"]
        }
      }
    },
    {
      "id": 7,
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 8 },
      "type": "timeseries",
      "title": "Neo4j Query Latency (p95)",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(skuel_neo4j_query_duration_seconds_bucket[5m]))",
          "legendFormat": "{{operation}} {{label}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "unit": "s"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "mean", "max"]
        }
      }
    },
    {
      "id": 8,
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 1 },
      "type": "row",
      "title": "System Resources",
      "collapsed": false
    },
    {
      "id": 9,
      "gridPos": { "x": 0, "y": 19, "w": 6, "h": 6 },
      "type": "stat",
      "title": "Neo4j Connection Status",
      "targets": [
        {
          "expr": "skuel_neo4j_connected",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        },
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "red"
              },
              {
                "value": 1,
                "color": "green"
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              }
            }
          ]
        }
      }
    },
    {
      "id": 10,
      "gridPos": { "x": 6, "y": 19, "w": 6, "h": 6 },
      "type": "gauge",
      "title": "Total HTTP Requests (5m)",
      "targets": [
        {
          "expr": "sum(increase(skuel_http_requests_total[5m])) or vector(0)",
          "refId": "A"
        }
      ],
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 100,
                "color": "yellow"
              },
              {
                "value": 500,
                "color": "red"
              }
            ]
          },
          "unit": "short"
        }
      }
    },
    {
      "id": 11,
      "gridPos": { "x": 12, "y": 19, "w": 6, "h": 6 },
      "type": "gauge",
      "title": "Total Neo4j Queries (5m)",
      "targets": [
        {
          "expr": "sum(increase(skuel_neo4j_queries_total[5m])) or vector(0)",
          "refId": "A"
        }
      ],
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 1000,
                "color": "yellow"
              },
              {
                "value": 5000,
                "color": "red"
              }
            ]
          },
          "unit": "short"
        }
      }
    },
    {
      "id": 12,
      "gridPos": { "x": 18, "y": 19, "w": 6, "h": 6 },
      "type": "stat",
      "title": "Python Process Memory",
      "targets": [
        {
          "expr": "process_virtual_memory_bytes",
          "legendFormat": "Virtual Memory",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        },
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes"
        }
      }
    }
  ],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
  },
  "uid": "skuel-system-health",
  "fiscalYearStartMonth": 0
}
