
● Yes, exactly. The protocol would define the common interface that all domains share, but each domain's SearchService can have additional domain-specific methods.

  Protocol Pattern: Common + Domain-Specific

  # Core protocol - every domain implements these
  class SearchOperations(Protocol[T]):
      """Standard search interface across all activity domains."""

      # Universal methods (all domains)
      async def search(self, query: str, limit: int = 50) -> Result[list[T]]
      async def get_by_status(self, status: str, limit: int = 100) -> Result[list[T]]
      async def get_prioritized(self, user_context: UserContext, limit: int = 10) -> Result[list[T]]

  Then each domain extends with its own methods:

  # GoalsSearchService implements SearchOperations[Goal] PLUS:
  class GoalsSearchService(BaseService[GoalsOperations, Goal]):
      # Protocol methods (common)
      async def search(self, query: str, limit: int = 50) -> Result[list[Goal]]: ...
      async def get_by_status(self, status: str, limit: int = 100) -> Result[list[Goal]]: ...
      async def get_prioritized(self, user_context: UserContext, limit: int = 10) -> Result[list[Goal]]: ...

      # Domain-specific (Goals only)
      async def get_goals_by_timeframe(self, timeframe: GoalTimeframe) -> Result[list[Goal]]: ...
      async def get_goals_needing_habits(self, user_context: UserContext) -> Result[list[Goal]]: ...
      async def get_goals_blocked_by_knowledge(self, user_context: UserContext) -> Result[list[Goal]]: ...


  # HabitsSearchService implements SearchOperations[Habit] PLUS:
  class HabitsSearchService(BaseService[HabitsOperations, Habit]):
      # Protocol methods (common)
      async def search(self, query: str, limit: int = 50) -> Result[list[Habit]]: ...
      async def get_by_status(self, status: str, limit: int = 100) -> Result[list[Habit]]: ...
      async def get_prioritized(self, user_context: UserContext, limit: int = 10) -> Result[list[Habit]]: ...

      # Domain-specific (Habits only)
      async def get_habits_by_frequency(self, frequency: HabitFrequency) -> Result[list[Habit]]: ...
      async def get_habits_needing_attention(self, streak_threshold: int = 3) -> Result[list[Habit]]: ...
      async def get_habits_supporting_goal(self, goal_uid: str) -> Result[list[Habit]]: ...


  # TasksSearchService implements SearchOperations[Task] PLUS:
  class TasksSearchService(BaseService[TasksOperations, Task]):
      # Protocol methods (common)
      async def search(self, query: str, limit: int = 50) -> Result[list[Task]]: ...
      async def get_by_status(self, status: str, limit: int = 100) -> Result[list[Task]]: ...
      async def get_prioritized(self, user_context: UserContext, limit: int = 10) -> Result[list[Task]]: ...

      # Domain-specific (Tasks only)
      async def get_tasks_for_goal(self, goal_uid: str) -> Result[list[Task]]: ...
      async def get_tasks_for_habit(self, habit_uid: str) -> Result[list[Task]]: ...
      async def get_curriculum_tasks(self) -> Result[list[Task]]: ...
      async def get_learning_relevant_tasks(self, learning_position: LpPosition) -> Result[list[Task]]: ...

  Domain-Specific Search Examples

  | Domain     | Domain-Specific Search Methods                                                                     |
  |------------|----------------------------------------------------------------------------------------------------|
  | Tasks      | get_tasks_for_goal(), get_tasks_for_habit(), get_curriculum_tasks(), get_learning_relevant_tasks() |
  | Goals      | get_goals_by_timeframe(), get_goals_needing_habits(), get_goals_blocked_by_knowledge()             |
  | Habits     | get_habits_by_frequency(), get_habits_needing_attention(), get_habits_supporting_goal()            |
  | Events     | get_events_in_range(), get_recurring_events(), get_events_for_goal()                               |
  | Choices    | get_pending_choices(), get_choices_by_urgency(), get_choices_affecting_goal()                      |
  | Principles | get_principles_by_domain(), get_principles_guiding_goal(), get_active_principles()                 |

  Benefits of This Approach

  1. Consistency - All domains have search(), get_by_status(), get_prioritized()
  2. Flexibility - Each domain adds what makes sense for its semantics
  3. Discoverability - Developers know where to find search functionality
  4. Testability - Protocol defines contract for mocking
  5. Askesis Integration - Unified search interface for cross-domain queries


