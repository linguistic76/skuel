Copy this into a file named `KU-content-learning.cypher` and run with `cypher-shell` or via your Neo4j driver (pass `raw_json` as a parameter if you want the snapshot stored).

```cypher
// --- KU-content-learning.cypher
// Create uniqueness constraints if not already created (run once)
// CREATE CONSTRAINT ON (k:KnowledgeUnit) ASSERT k.uid IS UNIQUE;

// 1) Create / update the main KnowledgeUnit node
MERGE (ku:KnowledgeUnit {uid: 'KU-content-learning'})
SET ku.title = 'Content and Learning',
    ku.type = 'domain',
    ku.domains = ['skuel','knowledge'],
    ku.description = 'Learning paths as the backbone of content. Paths gain weight through five domains: tasks, events, habits, goals, principles.',
    ku.notes = "Tier 1 in the three-tier system. Focus on knowledge creation and user learning journeys.",
    ku.updated = date(),
    ku.raw_json = $raw_json;  // optional: pass the original YAML/JSON string as parameter

// 2) SUPPORTS relationships (these are KnowledgeUnit nodes the KU supports)
WITH ku
UNWIND [
  'KU-learning-paths',
  'KU-tasks',
  'KU-events',
  'KU-habits',
  'KU-goals',
  'KU-principles'
] AS refUid
MERGE (ref:KnowledgeUnit {uid: refUid})
MERGE (ku)-[:SUPPORTS]->(ref);

// 3) RELATED_TO relationships (looser semantic links)
WITH ku
UNWIND [
  'KU-compounding',
  'KU-goals-habits-principles',
  'KU-three-in-one'
] AS refUid
MERGE (ref:KnowledgeUnit {uid: refUid})
MERGE (ku)-[:RELATED_TO]->(ref);

// 4) Optionally attach domain nodes (useful if you model domains as nodes)
WITH ku
UNWIND ['skuel','knowledge'] AS dom
MERGE (d:KnowledgeDomain {uid: dom})
MERGE (ku)-[:IN_DOMAIN]->(d);

// 5) Return the created node for verification
RETURN ku;
```

