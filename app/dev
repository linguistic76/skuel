#!/bin/bash
# SKUEL Development Command Runner
# =================================
# Quick access to common development commands
#
# Usage: ./dev <command>

set -e  # Exit on error

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

case "$1" in
  format)
    echo -e "${GREEN}Formatting code...${NC}"
    uv run ruff format
    echo -e "${GREEN}✓ Formatting complete${NC}"
    ;;

  format-check)
    echo -e "${YELLOW}Checking formatting...${NC}"
    uv run ruff format --check
    ;;

  lint)
    echo -e "${YELLOW}Running linters...${NC}"
    failed=0
    uv run ruff check || failed=1
    uv run python scripts/lint_skuel.py || failed=1
    if [ $failed -eq 1 ]; then
      echo -e "${RED}✗ Lint checks found issues${NC}"
      exit 1
    fi
    ;;

  lint-fix)
    echo -e "${GREEN}Auto-fixing lint issues...${NC}"
    uv run ruff check --fix
    ;;

  quality)
    echo -e "${YELLOW}Running all quality checks...${NC}"
    uv run python scripts/run_quality_checks.py
    ;;

  quality-fix)
    echo -e "${GREEN}Running quality checks with auto-fix...${NC}"
    uv run python scripts/run_quality_checks.py --fix
    ;;

  bloat)
    echo -e "${YELLOW}Detecting bloat (unused code)...${NC}"
    uv run python scripts/detect_bloat.py
    ;;

  bloat-events)
    echo -e "${YELLOW}Detecting unused events...${NC}"
    uv run python scripts/detect_bloat.py --events-only
    ;;

  bloat-methods)
    echo -e "${YELLOW}Detecting unused service methods...${NC}"
    uv run python scripts/detect_bloat.py --methods-only
    ;;

  test)
    echo -e "${GREEN}Running COMPREHENSIVE test suite (recommended)${NC}"
    uv run python scripts/run_tests.py comprehensive
    ;;

  test-all)
    echo -e "${YELLOW}Running COMPLETE test suite (all 1,349 tests)${NC}"
    uv run python scripts/run_tests.py all
    ;;

  test-integration)
    echo -e "${GREEN}Running integration tests (fast)${NC}"
    uv run python scripts/run_tests.py integration
    ;;

  test-service)
    echo -e "${YELLOW}Running service tests only${NC}"
    uv run python scripts/run_tests.py service
    ;;

  test-unit)
    echo -e "${YELLOW}Running unit tests (many need Phase 2 migration updates)${NC}"
    uv run python scripts/run_tests.py unit
    ;;

  test-quick)
    echo -e "${GREEN}Running quick smoke test${NC}"
    uv run python scripts/run_tests.py quick
    ;;

  serve)
    echo -e "${GREEN}Starting SKUEL server...${NC}"
    uv run python main.py
    ;;

  css)
    echo -e "${GREEN}Watching CSS changes...${NC}"
    npm run css:watch
    ;;

  css-build)
    echo -e "${GREEN}Building CSS...${NC}"
    npm run css:build
    ;;

  css-prod)
    echo -e "${GREEN}Building minified CSS for production...${NC}"
    npm run css:prod
    ;;

  health)
    echo -e "${YELLOW}Running codebase health checks...${NC}"
    echo ""
    failed=0
    uv run python scripts/health/dead_modules.py || failed=1
    echo ""
    uv run python scripts/health/dead_doc_links.py || failed=1
    echo ""
    uv run python scripts/health/stale_names.py || failed=1
    echo ""
    uv run python scripts/validate_cross_references.py || failed=1
    echo ""
    if [ $failed -eq 1 ]; then
      echo -e "${RED}✗ Health check found issues — review output above${NC}"
      exit 1
    else
      echo -e "${GREEN}✓ All health checks passed${NC}"
    fi
    ;;

  health-modules)
    echo -e "${YELLOW}Checking for dead Python modules...${NC}"
    uv run python scripts/health/dead_modules.py
    ;;

  health-links)
    echo -e "${YELLOW}Checking for broken documentation links...${NC}"
    uv run python scripts/health/dead_doc_links.py
    ;;

  health-names)
    echo -e "${YELLOW}Checking for stale/deprecated names in docs...${NC}"
    uv run python scripts/health/stale_names.py
    ;;

  health-xref)
    echo -e "${YELLOW}Validating skill↔doc cross-references...${NC}"
    uv run python scripts/validate_cross_references.py
    ;;

  docs-check)
    echo -e "${YELLOW}Checking for documentation updates needed...${NC}"
    uv run python scripts/docs_contextual_check.py
    ;;

  docs-check-fast)
    echo -e "${YELLOW}Checking for documentation updates (fast mode, no LLM)...${NC}"
    uv run python scripts/docs_contextual_check.py --fast
    ;;

  up)
    echo -e "${GREEN}Starting full stack (Neo4j + App + Prometheus + Grafana)...${NC}"
    shift
    docker compose up "$@"
    ;;

  up-neo4j)
    echo -e "${GREEN}Starting Neo4j only (for local dev with uv run python main.py)...${NC}"
    docker compose up neo4j -d
    ;;

  down)
    echo -e "${YELLOW}Stopping all services...${NC}"
    shift
    docker compose down "$@"
    ;;

  help|*)
    echo "SKUEL Development Commands"
    echo "=========================="
    echo ""
    echo "Code Quality:"
    echo "  ./dev format         - Auto-format all Python files with Ruff"
    echo "  ./dev format-check   - Check formatting without changes"
    echo "  ./dev lint           - Run all linters (Ruff + SKUEL patterns)"
    echo "  ./dev lint-fix       - Auto-fix linting issues"
    echo "  ./dev quality        - Run ALL quality checks (format + lint + patterns + Cypher)"
    echo "  ./dev quality-fix    - Run quality checks with auto-fix"
    echo ""
    echo "Bloat Detection:"
    echo "  ./dev bloat          - Detect all unused code (events + methods)"
    echo "  ./dev bloat-events   - Detect unused events only"
    echo "  ./dev bloat-methods  - Detect unused service methods only"
    echo ""
    echo "Health Checks:"
    echo "  ./dev health         - Run all four health checks (modules + links + names + xref)"
    echo "  ./dev health-modules - Find Python files with zero importers"
    echo "  ./dev health-links   - Find broken links in docs/ and .claude/skills/"
    echo "  ./dev health-names   - Find stale/deprecated identifiers in doc code blocks"
    echo "  ./dev health-xref    - Validate skill↔doc cross-references and staleness"
    echo ""
    echo "Testing:"
    echo "  ./dev test              - Run comprehensive tests (~1,150 tests, ~95% pass) [RECOMMENDED]"
    echo "  ./dev test-all          - Run complete suite (1,349 tests, ~83% pass)"
    echo "  ./dev test-integration  - Run integration tests (434 tests, 100% pass) [FAST & RELIABLE]"
    echo "  ./dev test-service      - Run service tests (~600 tests, ~92% pass)"
    echo "  ./dev test-unit         - Run unit tests (only - many need Phase 2 migration updates)"
    echo "  ./dev test-quick        - Run quick smoke test (~350 tests, ~99% pass) [FASTEST]"
    echo ""
    echo "Documentation:"
    echo "  ./dev docs-check      - Check if docs need updating (based on recent changes)"
    echo "  ./dev docs-check-fast - Fast check (text search only, no LLM)"
    echo ""
    echo "Docker:"
    echo "  ./dev up             - Start full stack (Neo4j + App + Prometheus + Grafana)"
    echo "  ./dev up-neo4j       - Start Neo4j only (then: uv run python main.py)"
    echo "  ./dev down           - Stop all Docker services"
    echo ""
    echo "Development:"
    echo "  ./dev serve          - Start development server (requires Neo4j running)"
    echo "  ./dev css            - Watch and rebuild CSS on changes"
    echo "  ./dev css-build      - Build CSS once"
    echo "  ./dev css-prod       - Build minified CSS for production"
    echo ""
    echo "Examples:"
    echo "  ./dev format            # Before committing changes"
    echo "  ./dev quality-fix       # Fix all auto-fixable issues"
    echo "  ./dev test              # Comprehensive tests (recommended)"
    echo "  ./dev test-quick        # Fast smoke test (30s)"
    echo "  ./dev bloat-events      # Find unused events"
    echo ""
    echo "Advanced Test Options:"
    echo "  uv run python scripts/run_tests.py --help  # See all test runner options"
    ;;
esac
