{
  "uid": "skuel-user-journey",
  "title": "SKUEL User Journey & Intelligence",
  "description": "Search quality, UserContext operations, and recommendation tracking",
  "tags": ["skuel", "search", "intelligence", "user-journey"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["10s", "30s", "1m", "5m", "15m"]
  },
  "templating": {
    "list": [
      {
        "name": "search_type",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(skuel_searches_total, search_type)",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "hide": 0,
        "includeAll": true,
        "multi": false,
        "options": [],
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "sort": 0,
        "type": "query"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Search Activity",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "collapsed": false
    },
    {
      "id": 2,
      "type": "piechart",
      "title": "Searches by Type",
      "description": "Distribution of vector, fulltext, and hybrid searches",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 1},
      "targets": [
        {
          "expr": "sum(increase(skuel_searches_total[1h])) by (search_type)",
          "refId": "A",
          "legendFormat": "{{search_type}}"
        }
      ],
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "values": ["value", "percent"]},
        "pieType": "pie",
        "displayLabels": ["name", "percent"]
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Search Latency (p95)",
      "description": "95th percentile search query duration",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 1},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(skuel_search_duration_seconds_bucket{search_type=~\"$search_type\"}[1m])) by (search_type, le))",
          "refId": "A",
          "legendFormat": "{{search_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          },
          "unit": "s"
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last", "max"]}
      }
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "Average Similarity Score",
      "description": "Mean search result similarity (0.0-1.0, higher is better)",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 1},
      "targets": [
        {
          "expr": "avg(skuel_search_similarity_score{search_type=~\"$search_type\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 1,
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": 0},
              {"color": "orange", "value": 0.5},
              {"color": "yellow", "value": 0.7},
              {"color": "green", "value": 0.8}
            ]
          }
        }
      },
      "options": {
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 5,
      "type": "row",
      "title": "Search Quality Trends",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "collapsed": false
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Search Quality Over Time",
      "description": "Similarity score trends by search type",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "targets": [
        {
          "expr": "avg(skuel_search_similarity_score{search_type=~\"$search_type\"}) by (search_type)",
          "refId": "A",
          "legendFormat": "{{search_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          },
          "unit": "short",
          "min": 0,
          "max": 1
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last", "mean"]}
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Search Volume by Type",
      "description": "Search requests per minute",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10},
      "targets": [
        {
          "expr": "sum(rate(skuel_searches_total{search_type=~\"$search_type\"}[1m])) by (search_type)",
          "refId": "A",
          "legendFormat": "{{search_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "stacking": {"mode": "normal"}
          },
          "unit": "reqps"
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last", "max"]}
      }
    },
    {
      "id": 8,
      "type": "row",
      "title": "Event Bus Activity",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18},
      "collapsed": false
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Event Publication Rate",
      "description": "Domain events published per second",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 19},
      "targets": [
        {
          "expr": "sum(rate(skuel_events_published_total[1m]))",
          "refId": "A",
          "legendFormat": "Events/sec"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          },
          "unit": "ops"
        }
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"}
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Event Handler Performance",
      "description": "p95 event handler execution time",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 19},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(skuel_event_handler_duration_seconds_bucket[1m])) by (le))",
          "refId": "A",
          "legendFormat": "p95 handler duration"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          },
          "unit": "s"
        }
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"}
      }
    },
    {
      "id": 11,
      "type": "row",
      "title": "Summary Stats",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 27},
      "collapsed": false
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Total Searches (1h)",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 28},
      "targets": [
        {
          "expr": "sum(increase(skuel_searches_total{search_type=~\"$search_type\"}[1h]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "palette-classic"}
        }
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value"
      }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Events Published (1h)",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 28},
      "targets": [
        {
          "expr": "sum(increase(skuel_events_published_total[1h]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "palette-classic"}
        }
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value"
      }
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Event Handler Calls (1h)",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 28},
      "targets": [
        {
          "expr": "sum(increase(skuel_event_handler_calls_total[1h]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "palette-classic"}
        }
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value"
      }
    },
    {
      "id": 15,
      "type": "stat",
      "title": "Event Handler Errors (1h)",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 28},
      "targets": [
        {
          "expr": "sum(increase(skuel_event_handler_errors_total[1h]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          }
        }
      },
      "options": {
        "graphMode": "none",
        "colorMode": "background",
        "textMode": "value_and_name"
      }
    }
  ]
}
