    },
    {
      "id": 15,
      "gridPos": { "x": 12, "y": 35, "w": 4, "h": 4 },
      "type": "stat",
      "title": "Tasks Completed (1h)",
      "targets": [
        {
          "expr": "sum(increase(skuel_entities_completed_total{entity_type=\"task\"}[1h]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "blue"},
              {"value": 50, "color": "green"},
              {"value": 100, "color": "dark-green"}
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "textMode": "value_and_name",
        "colorMode": "background"
      }
    },
    {
      "id": 16,
      "gridPos": { "x": 16, "y": 35, "w": 4, "h": 4 },
      "type": "stat",
      "title": "Habits Completed (1h)",
      "targets": [
        {
          "expr": "sum(increase(skuel_entities_completed_total{entity_type=\"habit\"}[1h]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "blue"},
              {"value": 20, "color": "green"},
              {"value": 50, "color": "dark-green"}
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "textMode": "value_and_name",
        "colorMode": "background"
      }
    },
    {
      "id": 17,
      "gridPos": { "x": 20, "y": 35, "w": 4, "h": 4 },
      "type": "stat",
      "title": "Total Events (1h)",
      "targets": [
        {
          "expr": "sum(increase(skuel_events_published_total[1h]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 500, "color": "yellow"},
              {"value": 1000, "color": "red"}
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "textMode": "value_and_name",
        "colorMode": "background"
      }
    }
  ],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
  },
  "uid": "skuel-domain-activity",
  "fiscalYearStartMonth": 0
}
