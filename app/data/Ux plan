 Architecture Decisions

 1. Markdown Rendering (Server-Side)

 Approach: Python markdown package with extensions
 Rationale: Better SEO, consistent styling, server-side caching, no JavaScript dependency

 # /core/utils/markdown_renderer.py
 import markdown
 from markdown.extensions import fenced_code, tables, toc, codehilite

 class MarkdownRenderer:
     """Server-side markdown to HTML converter with caching"""

     def __init__(self):
         self.md = markdown.Markdown(extensions=[
             'fenced_code',      # Code blocks with syntax
             'tables',           # Table support
             'toc',              # Table of contents generation
             'codehilite',       # Syntax highlighting (Pygments)
             'nl2br',            # Newline to <br>
             'sane_lists',       # Improved list handling
         ])

     def render(self, content: str) -> tuple[str, str]:
         """Returns (html_content, toc_html)"""
         html = self.md.convert(content)
         toc = self.md.toc
         self.md.reset()  # Reset for next conversion
         return html, toc

 Dependencies: Already in pyproject.toml (markdown>=3.4)

