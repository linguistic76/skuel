def _step_card(
    step_number: int,
    title: str,
    body: str,
    progress_fraction: float,
    bar_color: str,
    button_label: str,
    button_class: str,
    hx_get: str,
):
    frac = max(0.0, min(1.0, progress_fraction))
    width = int(frac * 100)

    return Article(
        Div(
            H2(f"{step_number}. {title}", class_=TOK["step_title"]),
            P(body, class_=TOK["step_body"]),
            Div(
                Div(
                    class_=f"{TOK['progress_bar_inner']} {bar_color}",
                    style=f"width: {width}%;",
