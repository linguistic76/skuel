 5. Knowledge Graph Navigation

 Component: /components/documentation_navigation.py

 Data Structure:
 @dataclass
 class KUNavigationData:
     """Knowledge graph navigation data for a KU"""
     prerequisites: list[Ku]      # REQUIRES relationships
     related: list[Ku]            # RELATED_TO relationships
     next_steps: list[Ku]         # ENABLES relationships
     found_in_lps: list[tuple[str, str]]    # LPs containing this KU
     found_in_mocs: list[tuple[str, str]]   # MOCs containing this KU

 Neo4j Queries:
 // Prerequisites (incoming REQUIRES)
 MATCH (ku:Ku {uid: $uid})<-[:REQUIRES]-(prereq:Ku)
 RETURN prereq

 // Related content (bidirectional RELATED_TO)
 MATCH (ku:Ku {uid: $uid})-[:RELATED_TO]-(related:Ku)
 RETURN related

 // Next steps (outgoing ENABLES)
 MATCH (ku:Ku {uid: $uid})-[:ENABLES]->(next:Ku)
 RETURN next

 // Found in LPs
 MATCH (lp:Lp)-[:CONTAINS_STEP]->(ls:Ls)-[:CONTAINS_KNOWLEDGE]->(ku:Ku {uid: $uid})
 RETURN lp.uid, lp.title

 // Found in MOCs
 MATCH (moc:Moc)-[:CONTAINS_KNOWLEDGE]->(ku:Ku {uid: $uid})
 RETURN moc.uid, moc.title

