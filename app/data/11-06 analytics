      result = await self.generate_report(
          user_uid=event.user_uid,
          report_type=ReportType.GOALS,
          period_start=period_start,
          period_end=period_end
      )

      if result.is_ok:
          self.logger.info(f"✅ Report generated: {result.value.uid}")
