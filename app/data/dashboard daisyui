@rt("/dashboard")
def get_dashboard():
    content = Section(cls="grid gap-4 lg:grid-cols-3")(
        # Primary column
        Div(cls="lg:col-span-2 space-y-4")(
            Article(cls="bg-base-100 rounded-box shadow p-4")(
                Header(cls="flex items-center justify-between mb-2")(
                    H2(cls="text-lg font-semibold")("Today’s Focus"),
                    Span(cls="badge badge-outline text-xs")("Game of Life"),
                ),
                P(cls="text-sm opacity-80")(
                    "This is where you’ll surface the current Learning Path step, "
                    "key actions, and reflections for the day."
                ),
            ),
            # etc…
        ),
        # Side column
        Aside(cls="space-y-4")(
            # Askesis + Next Actions blocks
        )
    )

    return dashboard_layout("Dashboard", content)
