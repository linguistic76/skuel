   class ProcessingPipelineService:
       async def process_dsl_activity_line(
           self,
           user_uid: str,
           markdown_line: str
       ) -> Result[dict]:
           """Process DSL-tagged markdown activity line"""

           # Parse DSL tags
           dsl_parser = DSLParser()
           parsed = dsl_parser.parse(markdown_line)

           # Create primary entity
           entity = await self._create_entity(user_uid, parsed)

           # Create knowledge relationships
           if parsed.ku_uid:
