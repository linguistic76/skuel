  def calculate_life_alignment(self, life_path_knowledge_uids: list[str]) -> float:
      # Assumes: knowledge_mastery dict has all the UIDs
      # Assumes: Mastery values are 0.0-1.0
      # Assumes: No duplicates in life_path_knowledge_uids

      for ku_uid in life_path_knowledge_uids:
