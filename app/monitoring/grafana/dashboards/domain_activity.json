{
  "title": "SKUEL Domain Activity",
  "tags": ["skuel", "domains", "activity", "phase3"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "type": "row",
      "title": "Entity Creation & Completion",
      "collapsed": false
    },
    {
      "id": 2,
      "gridPos": { "x": 0, "y": 1, "w": 12, "h": 8 },
      "type": "timeseries",
      "title": "Entities Created (Rate)",
      "targets": [
        {
          "expr": "sum by (entity_type) (rate(skuel_entities_created_total[5m]))",
          "legendFormat": "{{entity_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "showPoints": "never",
            "stacking": {
              "mode": "normal"
            }
          },
          "unit": "ops"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "mean", "max"]
        }
      }
    },
    {
      "id": 3,
      "gridPos": { "x": 12, "y": 1, "w": 12, "h": 8 },
      "type": "timeseries",
      "title": "Entities Completed (Rate)",
      "targets": [
        {
          "expr": "sum by (entity_type) (rate(skuel_entities_completed_total[5m]))",
          "legendFormat": "{{entity_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "showPoints": "never",
            "stacking": {
              "mode": "normal"
            }
          },
          "unit": "ops"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "mean", "max"]
        }
      }
    },
    {
      "id": 4,
      "gridPos": { "x": 0, "y": 9, "w": 12, "h": 8 },
      "type": "barchart",
      "title": "Total Entities Created (Last Hour)",
      "targets": [
        {
          "expr": "sum by (entity_type) (increase(skuel_entities_created_total[1h]))",
          "legendFormat": "{{entity_type}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "always",
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 100,
        "legend": {
          "displayMode": "hidden"
        }
      }
    },
    {
      "id": 5,
      "gridPos": { "x": 12, "y": 9, "w": 12, "h": 8 },
      "type": "barchart",
      "title": "Total Entities Completed (Last Hour)",
      "targets": [
        {
          "expr": "sum by (entity_type) (increase(skuel_entities_completed_total[1h]))",
          "legendFormat": "{{entity_type}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "always",
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 100,
        "legend": {
          "displayMode": "hidden"
        }
      }
    },
    {
      "id": 6,
      "gridPos": { "x": 0, "y": 17, "w": 24, "h": 1 },
      "type": "row",
      "title": "Event Bus Metrics",
      "collapsed": false
    },
    {
      "id": 7,
      "gridPos": { "x": 0, "y": 18, "w": 12, "h": 8 },
      "type": "timeseries",
      "title": "Event Publication Rate",
      "targets": [
        {
          "expr": "sum by (event_type) (rate(skuel_events_published_total[5m]))",
          "legendFormat": "{{event_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "unit": "ops"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["lastNotNull", "mean", "max"]
        }
      }
    },
    {
      "id": 8,
      "gridPos": { "x": 12, "y": 18, "w": 12, "h": 8 },
      "type": "timeseries",
      "title": "Event Handler Call Rate",
      "targets": [
        {
          "expr": "sum by (event_type) (rate(skuel_event_handler_calls_total[5m]))",
          "legendFormat": "{{event_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "unit": "ops"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["lastNotNull", "mean", "max"]
        }
      }
    },
    {
      "id": 9,
      "gridPos": { "x": 0, "y": 26, "w": 12, "h": 8 },
      "type": "timeseries",
      "title": "Event Handler Duration (p95)",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (event_type, le) (rate(skuel_event_handler_duration_seconds_bucket[5m])))",
          "legendFormat": "{{event_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "unit": "s"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["lastNotNull", "mean", "max"]
        }
      }
    },
    {
      "id": 10,
      "gridPos": { "x": 12, "y": 26, "w": 12, "h": 8 },
      "type": "timeseries",
      "title": "Event Handler Errors",
      "targets": [
        {
          "expr": "sum by (event_type) (rate(skuel_event_handler_errors_total[5m]))",
          "legendFormat": "{{event_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "unit": "ops",
          "color": {
            "mode": "palette-classic",
            "fixedColor": "red"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["lastNotNull", "sum"]
        }
      },
      "alert": {
        "conditions": [
          {
            "evaluator": {
              "params": [0.1],
              "type": "gt"
            },
            "operator": {
              "type": "and"
            },
            "query": {
              "params": ["A", "5m", "now"]
            },
            "reducer": {
              "params": [],
              "type": "avg"
            },
            "type": "query"
          }
        ],
        "executionErrorState": "alerting",
        "frequency": "1m",
        "handler": 1,
        "name": "Event Handler Errors Alert",
        "noDataState": "no_data"
      }
    },
    {
      "id": 11,
      "gridPos": { "x": 0, "y": 34, "w": 24, "h": 1 },
      "type": "row",
      "title": "Activity Summary",
      "collapsed": false
    },
    {
      "id": 12,
      "gridPos": { "x": 0, "y": 35, "w": 4, "h": 4 },
      "type": "stat",
      "title": "Tasks Created (1h)",
      "targets": [
        {
          "expr": "sum(increase(skuel_entities_created_total{entity_type=\"task\"}[1h]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 50, "color": "yellow"},
              {"value": 100, "color": "red"}
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "textMode": "value_and_name",
        "colorMode": "background"
      }
    },
    {
      "id": 13,
      "gridPos": { "x": 4, "y": 35, "w": 4, "h": 4 },
      "type": "stat",
      "title": "Goals Created (1h)",
      "targets": [
        {
          "expr": "sum(increase(skuel_entities_created_total{entity_type=\"goal\"}[1h]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 20, "color": "yellow"},
              {"value": 50, "color": "red"}
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "textMode": "value_and_name",
        "colorMode": "background"
      }
    },
    {
      "id": 14,
      "gridPos": { "x": 8, "y": 35, "w": 4, "h": 4 },
      "type": "stat",
      "title": "Habits Created (1h)",
      "targets": [
        {
          "expr": "sum(increase(skuel_entities_created_total{entity_type=\"habit\"}[1h]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
