##### 2. Stage 1 fastHTML page (with HTMX hooks)

This assumes something like:

```python
from fasthtml.common import *
from ui.objectivity_tokens import TOK
```

Then:

```python
# ui/objectivity_stage1.py

from fasthtml.common import *
from ui.objectivity_tokens import TOK


def stage1_see_what_is():
    """
    Stage 1 page: 'See What Is'.

    HTMX endpoints (examples):
      - /objectivity/stage1/step/1   → load Attention step
      - /objectivity/stage1/step/2   → load Thought ≠ Reality step
      - /objectivity/stage1/live     → start a live example flow with Askesis
    """
    return Main(
        Section(
            # Header
            Div(
                P("Stage 1", class_=TOK["stage_header_label"]),
                H1("See What Is", class_=TOK["stage_title"]),
                P(
                    "The skill of clear perception. You learn to tell the difference "
                    "between what is actually happening and what your mind says is happening.",
                    class_=TOK["stage_subtitle"],
                ),
                Div(
                    Span(
                        Span(class_="h-1.5 w-8 rounded-full bg-emerald-500"),
                        " attention",
                        class_="inline-flex items-center gap-1",
                    ),
                    Span(
                        Span(class_="h-1.5 w-8 rounded-full bg-sky-500"),
                        " thought vs reality",
                        class_="inline-flex items-center gap-1",
                    ),
                    class_="flex items-center gap-3 text-[11px] text-slate-500 mt-2",
                ),
                class_="space-y-3",
            ),

            # Steps list
            Section(
                _step_card(
                    step_number=1,
                    title="Attention · noticing what your mind is doing",
                    body="Catch when you are lost in thoughts instead of being with "
                         "what is actually happening.",
                    progress_fraction=0.75,
                    bar_color="bg-emerald-500",
                    button_label="Continue",
                    button_class=TOK["primary_btn"],
                    # HTMX hook: load step content into #stage1-detail
                    hx_get="/objectivity/stage1/step/1",
                    hx_target="#stage1-detail",
                    hx_swap="innerHTML",
                ),
                _step_card(
                    step_number=2,
                    title="Thought ≠ reality",
                    body="Learn to see thoughts as mental events, not facts. "
                         "Separate situation from story.",
                    progress_fraction=0.20,
                    bar_color="bg-sky-500",
                    button_label="Start",
                    button_class=TOK["secondary_btn"],
                    hx_get="/objectivity/stage1/step/2",
                    hx_target="#stage1-detail",
                    hx_swap="innerHTML",
                ),
                _locked_step_card(
                    step_number=3,
                    title="Emotional literacy",
                    body="Feelings are signals, not instructions. Notice how your "
                         "body responds without letting it run the whole story.",
                ),
                _coming_soon_step_card(
                    step_number=4,
                    title="Clear perception",
                    body="Remove filters like fear and habit, without removing emotion "
                         "itself. See the moment with less distortion.",
                ),
                class_="space-y-3 mt-6",
            ),

            # Askesis live example CTA
            Section(
                Div(
                    Div(
                        H2("Try it on something real", class_=TOK["cta_title"]),
                        P(
                            "Askesis can take a real situation from today and walk you "
                            "through seeing it clearly, step by step.",
                            class_=TOK["cta_body"],
                        ),
                        class_="space-y-1",
                    ),
                    A(
                        "Start a live example",
                        href="#",
                        class_=TOK["cta_btn"],
                        # HTMX: start a live SEE/ACCEPT/ACT session in a modal or panel
                        **{
                            "hx-get": "/objectivity/stage1/live",
                            "hx-target": "#askesis-modal",
                            "hx-swap": "innerHTML",
                        }
                    ),
                    class_=TOK["cta_card"],
                ),
                class_="mt-6",
            ),

            class_=f"{TOK['container']} space-y-6",
        ),
        # Detail area for HTMX-loaded step content (e.g., the Thought ≠ Reality exercise)
        Section(
            Div(
                # initially blank / placeholder; HTMX will inject content here
                P(
                    "Pick a step above to dive into a focused practice.",
                    class_="text-xs text-slate-500",
                ),
                id="stage1-detail",
                class_="mt-6",
            ),
            class_=f"{TOK['container']}",
        ),
        class_=TOK["section_outer"],
    )
```

Helper functions for step cards:

```python
def _step_card(
    step_number: int,
    title: str,
    body: str,
    progress_fraction: float,
    bar_color: str,
    button_label: str,
    button_class: str,
    hx_get: str,
    hx_target: str,
    hx_swap: str,
):
    # clamp fraction between 0 and 1
    frac = max(0.0, min(1.0, progress_fraction))
    width = int(frac * 100)

    return Article(
        Div(
            H2(
                f"{step_number}. {title}",
                class_=TOK["step_title"],
            ),
            P(
                body,
                class_=TOK["step_body"],
            ),
            Div(
                Div(
                    class_=f"{TOK['progress_bar_inner']} {bar_color}",
                    style=f"width: {width}%;",
                ),
                class_=TOK["progress_bar_outer"],
            ),
            class_="space-y-1",
        ),
        A(
            button_label,
            href="#",
            class_=button_class,
            **{
                "hx-get": hx_get,
                "hx-target": hx_target,
                "hx-swap": hx_swap,
            }
        ),
        class_=TOK["step_card"],
    )


def _locked_step_card(step_number: int, title: str, body: str):
    return Article(
        Div(
            H2(
                f"{step_number}. {title}",
                class_=TOK["step_title"],
            ),
            P(
                body,
                class_=TOK["step_body"],
            ),
            Div(
                Div(class_=TOK["progress_bar_inner"] + " bg-slate-600", style="width: 0%;"),
                class_=TOK["progress_bar_outer"],
            ),
            class_="space-y-1",
        ),
        Button(
            "Unlock after Step 2",
            type="button",
            class_=TOK["locked_btn"],
        ),
        class_=TOK["step_card"],
    )


def _coming_soon_step_card(step_number: int, title: str, body: str):
    return Article(
        Div(
            H2(
                f"{step_number}. {title}",
                class_=TOK["step_title_muted"],
            ),
            P(
                body,
                class_=TOK["step_body_muted"],
            ),
            class_="space-y-1",
        ),
        Span(
            "Coming after Step 3",
            class_="shrink-0 text-[10px] px-2 py-1 rounded-full bg-slate-900 "
                   "text-slate-500 border border-slate-800",
        ),
        class_=TOK["step_card_locked"],
    )
