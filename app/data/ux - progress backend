Then define the HTMX endpoint:

```python
# routes/objectivity_stage1_routes.py

from fasthtml.common import *
from progress.service import ProgressService
from ui.objectivity_stage1 import stage1_see_what_is
from ui.objectivity_step1 import step1_attention
from ui.objectivity_step2 import step2_thought_not_reality
from ui.objectivity_step3 import step3_emotional_literacy
from ui.objectivity_step4 import step4_clear_perception

app = FastHTML()
PATH_ID = "lp_path_of_objectivity"
progress_service = ProgressService(PATH_ID)


def _current_user_id() -> str:
    # TODO: swap for real auth later
    return "demo-user"


@app.get("/objectivity/stage1")
def stage1():
    user_id = _current_user_id()
    return stage1_see_what_is(user_id, progress_service)


@app.get("/objectivity/stage1/step/1")
def stage1_step1():
    return step1_attention()


@app.get("/objectivity/stage1/step/2")
def stage1_step2():
    # mark in progress when they open the step
    user_id = _current_user_id()
    progress_service.mark_in_progress(user_id, stage=1, step=2)
    return step2_thought_not_reality()


@app.get("/objectivity/stage1/step/3")
def stage1_step3():
    user_id = _current_user_id()
    return step3_emotional_literacy()


@app.get("/objectivity/stage1/step/4")
def stage1_step4():
    user_id = _current_user_id()
    return step4_clear_perception()


@app.post("/objectivity/stage1/step/2/complete")
def stage1_step2_complete():
    """
    HTMX endpoint called when user clicks 'Mark step as practiced'.
    Re-renders the Stage 1 page with updated progress, swapped into #stage1-root.
    """
    user_id = _current_user_id()
    progress_service.mark_done(user_id, stage=1, step=2)
    # Optionally, you could also automatically unlock step 3:
    progress_service.mark_in_progress(user_id, stage=1, step=3)
    return stage1_see_what_is(user_id, progress_service)
```

Now the flow is:

* User clicks Stage 1 → page rendered with per-step status
* User opens Step 2 → status becomes `in_progress`
* User clicks “Mark step as practiced” → POST → mark `done` → re-render Stage 1 with updated progress + Step 3 unlocked

You can copy the same pattern later for Stage 2 and Stage 3.

