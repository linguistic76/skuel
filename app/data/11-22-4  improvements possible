####   A. Learning Gap Analysis

  async def find_learning_gaps(self, user_uid: str, target_ku_uid: str):
      """Find shortest path to learn target, given what user already knows."""

      query = """
      // Find user's current knowledge
      MATCH (user:User {uid: $user_uid})-[:MASTERED]->(mastered:Knowledge)

      // Find target knowledge
      MATCH (target:Knowledge {uid: $target_uid})

      // Find shortest path from ANY mastered knowledge to target
      MATCH path = shortestPath(
          (mastered)-[:REQUIRES_KNOWLEDGE|EXTENDS_PATTERN*1..5]-(target)
      )

      // Filter out knowledge user already has
      WHERE NONE(node IN nodes(path) |
          (user)-[:MASTERED]->(node) AND node <> mastered
      )

      RETURN path,
             [node IN nodes(path) | node.uid] as learning_path,
             length(path) as steps_to_mastery
      ORDER BY length(path) ASC
      LIMIT 5
      """

  Use case: "You're 3 steps away from learning X - here's the shortest path"

#### B. Habit Chain Detection

  async def find_habit_chains(self, habit_uid: str):
      """Find reliable habit chains (what naturally follows this habit)."""

      query = """
      MATCH path = (start:Habit {uid: $uid})-[:TRIGGERS_AFTER*1..3]->(end:Habit)
      WHERE ALL(rel IN relationships(path) |
          rel.confidence >= 0.7  // Reliable chain
      )
      WITH path,
           [node IN nodes(path) | node.consistency_score] as consistency_scores
      WHERE ALL(score IN consistency_scores | score >= 0.8)

      RETURN path,
             [node IN nodes(path) | {uid: node.uid, title: node.title}] as habit_chain,
             reduce(avg = 0.0, score IN consistency_scores | avg + score) / size(consistency_scores) as chain_strength
      ORDER BY chain_strength DESC
      """

  Use case: "These 3 habits chain well - do morning meditation → focused work → deep learning"

  C. Cross-Domain Knowledge Bridges

  async def find_cross_domain_bridges(self, from_domain: Domain, to_domain: Domain):
      """Find how different domains connect (interdisciplinary insights)."""

      query = """
      MATCH path = shortestPath(
          (tech:Knowledge {domain: $from_domain})-[*1..5]-(business:Knowledge {domain: $to_domain})
      )
      WHERE ALL(rel IN relationships(path) |
          type(rel) IN ['APPLIES_KNOWLEDGE_TO', 'SHARES_PRINCIPLE_WITH']
          AND rel.confidence >= 0.6
      )

      RETURN path,
             [node IN nodes(path) | {uid: node.uid, title: node.title, domain: node.domain}] as bridge_path,
             [rel IN relationships(path) | type(rel)] as relationship_types
      ORDER BY length(path) ASC
      LIMIT 10
      """

  Use case: "Here's how your Python knowledge applies to Business Strategy"


