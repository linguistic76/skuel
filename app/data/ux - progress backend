##### 1. Tiny progress model + in-memory store

```python
# progress/model.py

from dataclasses import dataclass
from typing import Dict, Tuple, Literal

StepStatus = Literal["not_started", "in_progress", "done"]


@dataclass
class StepProgress:
    user_id: str
    path_id: str          # e.g. "lp_path_of_objectivity"
    stage: int            # 1, 2, 3
    step: int             # 1..N within stage
    status: StepStatus    # "not_started" | "in_progress" | "done"


# super tiny in-memory store for now: {(user_id, path_id, stage, step): StepProgress}
_PROGRESS_STORE: Dict[Tuple[str, str, int, int], StepProgress] = {}
```

---

##### 2. ProgressService with a clean interface

```python
# progress/service.py

from typing import Dict, Tuple
from .model import StepProgress, StepStatus, _PROGRESS_STORE


class ProgressService:
    """
    Tiny progress service that can later be swapped for Neo4j or another backend.
    """

    def __init__(self, path_id: str):
        self.path_id = path_id   # e.g. "lp_path_of_objectivity"

    def _key(self, user_id: str, stage: int, step: int) -> Tuple[str, str, int, int]:
        return user_id, self.path_id, stage, step

    def get_step_status(self, user_id: str, stage: int, step: int) -> StepStatus:
        key = self._key(user_id, stage, step)
        if key not in _PROGRESS_STORE:
            return "not_started"
        return _PROGRESS_STORE[key].status

    def set_step_status(self, user_id: str, stage: int, step: int, status: StepStatus) -> None:
        key = self._key(user_id, stage, step)
        _PROGRESS_STORE[key] = StepProgress(
            user_id=user_id,
            path_id=self.path_id,
            stage=stage,
            step=step,
            status=status,
        )

    def mark_in_progress(self, user_id: str, stage: int, step: int) -> None:
        current = self.get_step_status(user_id, stage, step)
        if current == "not_started":
            self.set_step_status(user_id, stage, step, "in_progress")

    def mark_done(self, user_id: str, stage: int, step: int) -> None:
        self.set_step_status(user_id, stage, step, "done")

    def get_stage_progress(self, user_id: str, stage: int) -> Dict[int, StepStatus]:
        """
        Returns {step_number: status} for a given stage.
        """
        result: Dict[int, StepStatus] = {}
        # assume at most 4 steps for now; adjust as needed
        for step in range(1, 5):
            result[step] = self.get_step_status(user_id, stage, step)
        return result
```

You can later swap `_PROGRESS_STORE` for Neo4j by implementing the same methods using Cypher, without touching the UI.

